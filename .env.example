# 环境变量模板 — 复制为 .env 并填入实际值
# Environment Variables Template — Copy to .env and fill in your values

# ════════════════════════════════════════════════════
# LLM 提供商 API Key / LLM Provider API Keys
# 至少配置一个 / At least one is required
# ════════════════════════════════════════════════════
ZAI_API_KEY=                    # 智谱 GLM API Key (https://open.bigmodel.cn)
DEEPSEEK_API_KEY=               # DeepSeek API Key (https://api.deepseek.com)
GOOGLE_API_KEY=                 # Google/Gemini API Key
OPENAI_API_KEY=                 # OpenAI API Key

# ════════════════════════════════════════════════════
# 搜索引擎 API Key / Search Engine API Keys
# ════════════════════════════════════════════════════
BRAVE_SEARCH_API_KEY=           # Brave Search API Key
TAVILY_API_KEY=                 # Tavily Search API Key
FIRECRAWL_API_KEY=              # Firecrawl API Key (optional)

# ════════════════════════════════════════════════════
# 飞书通道 / Feishu Channel
# ════════════════════════════════════════════════════
FEISHU_APP_ID=                  # 飞书应用 ID / Feishu App ID
FEISHU_APP_SECRET=              # 飞书应用密钥 / Feishu App Secret

# ════════════════════════════════════════════════════
# Telegram 通道 / Telegram Channel
# ════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=             # Telegram Bot Token (from @BotFather)

# ════════════════════════════════════════════════════
# 邮件 / Email
# ════════════════════════════════════════════════════
GMAIL_ADDRESS=                  # Gmail 地址 / Gmail address
GMAIL_APP_PASSWORD=             # Gmail 应用专用密码 / Gmail App Password
MAIL_163_ADDRESS=               # 163 邮箱地址 / 163 Mail address (optional)
163_IMAP_PASSWORD=              # 163 邮箱 IMAP 密码 / 163 Mail IMAP password (optional)

# ════════════════════════════════════════════════════
# 安全 / Security
# ════════════════════════════════════════════════════
MYAGENT_INTERNAL_SECRET=        # 内部 API 认证密钥 / Internal API auth secret (random string)
